{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.AspNetCore.Http.Connections": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "users-api-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/users/{**catch-all}"
          }
        ],
        "Order": 2
      },
      "auth-api-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/auth/{**catch-all}"
          }
        ],
        "Order": 2
      },
      "admin-api-route": {
        "ClusterId": "users-cluster",
        "Match": {
          "Path": "/api/admin/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/admin/{**catch-all}"
          }
        ],
        "Order": 2
      },
      "catalog-games-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/games/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/games/{**catch-all}"
          }
        ],
        "Order": 2
      },
      "catalog-user-games-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/user-games/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/user-games/{**catch-all}"
          }
        ],
        "Order": 2
      },
      "catalog-orders-route": {
        "ClusterId": "catalog-cluster",
        "Match": {
          "Path": "/api/v1/orders/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/v1/orders/{**catch-all}"
          }
        ],
        "Order": 2
      },
      "payments-api-route": {
        "ClusterId": "payments-cluster",
        "Match": {
          "Path": "/api/payments/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/payments/{**catch-all}"
          }
        ],
        "Order": 2
      },
      "notifications-api-route": {
        "ClusterId": "notifications-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "/api/notifications/{**catch-all}"
          }
        ],
        "Order": 2
      }
    },
    "Clusters": {
      "users-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5000"
          }
        }
      },
      "catalog-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5013"
          }
        }
      },
      "payments-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "notifications-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      }
    }
  }
}
